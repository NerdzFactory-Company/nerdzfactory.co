VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Set to true to use Supabase Authentication (email/password) instead of demo mock users.
# Requires valid VITE_SUPABASE_* above. Create users in Supabase → Authentication → Users.
# Set to true to load tasks, announcements, leave, onboarding config, etc. from Supabase (portal_* tables).
# Requires VITE_USE_SUPABASE_AUTH=true, a logged-in user, and SQL migration 20260518120000_portal_data_tables.sql applied.
# VITE_USE_SUPABASE_DATA=false
