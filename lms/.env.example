# Copy to .env and fill in real values before `npm run build` / deploy.
# Deploy aborts if required production flags are missing or left in demo mode.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Production must use live backends (not silent demo / local-only mode).
VITE_USE_SUPABASE_AUTH=true
VITE_USE_SUPABASE_DATA=true
VITE_USE_PHONE_OTP=true

# Optional: inject sample worksheet submissions when none exist (dev only).
# VITE_LMS_MOCK_SUBMISSIONS=true
